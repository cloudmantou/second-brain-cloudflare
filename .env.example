# Self-host configuration (copy to .env)
# Cloudflare Worker still uses .dev.vars / wrangler secrets.

PORT=8787
HOST=0.0.0.0
AUTH_TOKEN=change-me-to-a-long-secret

# SQLite database file
DATABASE_PATH=./data/memory.db

# ── LLM (OpenAI-compatible: DeepSeek / MiniMax / MiMo / OpenAI) ──────────────
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ── Embedding (independent of LLM; keep dim consistent for a given DB) ───────
# Leave empty on self-host to use built-in local hash embeddings (dev quality).
# For production semantic search, point at an OpenAI-compatible embeddings API.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
# EMBEDDING_PROVIDER=local
# EMBEDDING_DIM=384

# Optional: Vectorize grace period (ms) for recent unvectorized entries
# VECTORIZE_GRACE_MS=300000
