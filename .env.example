# Self-host configuration (copy to .env)
# Cloudflare Worker still uses .dev.vars / wrangler secrets.

PORT=8787
# Prefer 127.0.0.1 when reverse-proxied; use 0.0.0.0 only if you understand the risk.
HOST=127.0.0.1
AUTH_TOKEN=change-me-to-a-long-secret

# ── Public site URL (global — set once for every deployer) ───────────────────
# Your HTTPS domain as users and ChatGPT/MCP open it. No trailing slash.
# Used for: OAuth issuer, discovery metadata, absolute redirect links, /config.
# Aliases (first non-empty wins): PUBLIC_URL | PUBLIC_BASE_URL | SITE_URL
PUBLIC_URL=https://your.domain.example
# PUBLIC_BASE_URL=
# SITE_URL=

# Personal-instance redirect allowlist (these are also the secure defaults).
# Loopback entries without a port allow any port. Use * only as an explicit,
# discouraged opt-out when another trusted MCP client requires a custom origin.
OAUTH_ALLOWED_REDIRECT_ORIGINS=https://chatgpt.com,http://127.0.0.1,http://localhost

DATABASE_PATH=./data/memory.db

# ── LLM (OpenAI-compatible) — or configure in Settings → Models & API ────────
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
# Optional JSON merged into chat body, e.g. thinking disabled is applied by default
# for DeepSeek/MiniMax models.
# LLM_EXTRA_BODY={"thinking":{"type":"disabled"}}

# ── Embedding (required for production) ─────────────────────────────────────
# Prefer explicit dimensions matching your index (Cloudflare Vectorize = 384).
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=384

# DEV ONLY — never enable on production corpora:
# ALLOW_DEV_EMBEDDING=true
# EMBEDDING_PROVIDER=local-hash-dev
